# Discord Bot Configuration
DISCORD_TOKEN=your_bot_token_here
CLIENT_ID=your_client_id_here
GUILD_ID=your_guild_id_here_for_dev   # optional: for guild-specific command deployment

# MongoDB
MONGODB_URI=mongodb://localhost:27017/socialbot
# or use MongoDB Atlas:
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/socialbot

# Environment
NODE_ENV=development
